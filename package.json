{
  "name": "schoolmanagementsoftware",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "rebuild": "electron-rebuild",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.svs.schoolmanagementsoftware",
    "productName": "School Management Software",
    "icon": "electron/favicon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^7.14.1",
